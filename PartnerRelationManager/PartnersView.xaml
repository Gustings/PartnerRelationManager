<UserControl x:Class="PartnerRelationManager.PartnersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="950">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: Partner Directory & Search -->
        <ui:Card Grid.Column="0" Padding="12" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Partners Directory" Margin="0,0,0,8"/>

                <ui:TextBox Grid.Row="1" x:Name="TxtSearchPartner" PlaceholderText="Search partners..." 
                            TextChanged="TxtSearchPartner_TextChanged" Margin="0,0,0,12" Icon="Search24"/>

                <ListBox Grid.Row="2" x:Name="LstPartners" SelectionChanged="LstPartners_SelectionChanged" 
                         DisplayMemberPath="Name" BorderThickness="0" Background="Transparent"/>

                <!-- Add Partner Action -->
                <StackPanel Grid.Row="3" Margin="0,12,0,0" >
                    <ui:TextBox x:Name="TxtNewPartnerName" PlaceholderText="New Partner Name"/>
                    <ui:Button Content="Add New Partner" Icon="Add24" Appearance="Secondary" 
                               Click="BtnAddPartner_Click" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- CENTER DETAIL VIEW -->
        <Grid Grid.Column="1">
            <!-- No Selection Overlay -->
            <ui:Card x:Name="CardNoSelection" Padding="32" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" >
                    <ui:SymbolIcon Symbol="PersonBoard24" FontSize="48" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="No Partner Selected" HorizontalAlignment="Center"/>
                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Select a partner from the directory list on the left to view and edit details." 
                                  Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </ui:Card>

            <!-- Details Panel -->
            <Grid x:Name="GridPartnerDetails" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Details Header with Country & Year filters -->
                <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Title and Owner -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtDetailPartnerName" Style="{DynamicResource TitleTextBlockStyle}" Text="Partner Name" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Owner: " Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TxtDetailPartnerOwner" Style="{DynamicResource CaptionTextBlockStyle}" Text="Owner Name" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Filters -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" >
                            <StackPanel >
                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Country" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                <ComboBox x:Name="CboCountry" Width="100" DisplayMemberPath="Code" SelectionChanged="CboFilter_SelectionChanged"/>
                            </StackPanel>
                            
                            <StackPanel >
                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Period / Year" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                <ComboBox x:Name="CboPeriod" Width="90" SelectionChanged="CboFilter_SelectionChanged">
                                    <ComboBoxItem Content="2025" IsSelected="True"/>
                                    <ComboBoxItem Content="2026"/>
                                    <ComboBoxItem Content="2027"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- Content Tabs -->
                <TabControl Grid.Row="1">
                    <!-- PROFILE TAB -->
                    <TabItem Header="Profile">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Partner Properties Form -->
                                <ui:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
                                    <StackPanel >
                                        <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Partner Profile Details"/>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Owner -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Internal Owner:"/>
                                                <ui:TextBox x:Name="TxtEditOwner"/>
                                            </StackPanel>
                                            <!-- Category -->
                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Category (OEM/Preferred):"/>
                                                <ui:TextBox x:Name="TxtEditCategory"/>
                                            </StackPanel>
                                            <!-- Strategic Importance -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Strategic Importance:"/>
                                                <ui:TextBox x:Name="TxtEditImportance"/>
                                            </StackPanel>
                                            <!-- Status -->
                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Status (Green/Amber/Red):"/>
                                                <ui:TextBox x:Name="TxtEditStatus"/>
                                            </StackPanel>
                                            <!-- Business Areas -->
                                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" >
                                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Business Areas / Primary Sales Model:"/>
                                                <ui:TextBox x:Name="TxtEditBusinessAreas"/>
                                            </StackPanel>
                                            <!-- Current Tier -->
                                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" >
                                                <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Current Partner Tier:"/>
                                                <ComboBox x:Name="CboPartnerTier" DisplayMemberPath="Name" SelectedValuePath="Id" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </Grid>

                                        <ui:Button Content="Save Profile Changes" Appearance="Primary" Click="BtnSaveProfile_Click" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </ui:Card>

                                <!-- Contacts & Products -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Contacts -->
                                    <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Contacts" Margin="0,0,0,8"/>
                                            <ListView Grid.Row="1" x:Name="LstContacts" Height="150">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="100"/>
                                                        <GridViewColumn Header="Role" DisplayMemberBinding="{Binding Role}" Width="100"/>
                                                        <GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="120"/>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                            <StackPanel Grid.Row="2" Margin="0,8,0,0" >
                                                <ui:TextBox x:Name="TxtNewContactName" PlaceholderText="Contact Name"/>
                                                <ui:TextBox x:Name="TxtNewContactRole" PlaceholderText="Role / Title"/>
                                                <ui:TextBox x:Name="TxtNewContactEmail" PlaceholderText="Email"/>
                                                <ui:Button Content="Add Contact" Click="BtnAddContact_Click" Appearance="Secondary" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:Card>

                                    <!-- Products / Services -->
                                    <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Products &amp; Services" Margin="0,0,0,8"/>
                                            <ListView Grid.Row="1" x:Name="LstProducts" Height="150">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="120"/>
                                                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="80"/>
                                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                            <StackPanel Grid.Row="2" Margin="0,8,0,0" >
                                                <ui:TextBox x:Name="TxtNewProdName" PlaceholderText="Product/Service Name"/>
                                                <ui:TextBox x:Name="TxtNewProdType" PlaceholderText="Type (e.g. Hardware, SaaS)"/>
                                                <ui:TextBox x:Name="TxtNewProdStatus" PlaceholderText="Status (e.g. Active, EOL)"/>
                                                <ui:Button Content="Add Product/Service" Click="BtnAddProduct_Click" Appearance="Secondary" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </Grid>
                                    </ui:Card>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <!-- KPI TRACKERS TAB -->
                    <TabItem Header="KPI Trackers">
                        <TabControl TabStripPlacement="Left">
                            <!-- COMMERCIAL KPI -->
                            <TabItem Header="Commercial">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ui:Card Padding="16" Margin="12">
                                        <StackPanel >
                                            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Commercial Performance KPI" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Annual Recurring Revenue (ARR):"/>
                                                    <ui:TextBox x:Name="TxtArr"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Upfront Revenue:"/>
                                                    <ui:TextBox x:Name="TxtUpfront"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="OEM Service Attach Rate (%):"/>
                                                    <ui:TextBox x:Name="TxtOemAttach"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Onitio Service Attach Rate (%):"/>
                                                    <ui:TextBox x:Name="TxtOnitioAttach"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Lifecycle Margin (%):"/>
                                                    <ui:TextBox x:Name="TxtLifecycleMargin"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Target Met:"/>
                                                    <ComboBox x:Name="CboCommercialTargetMet" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Comments:"/>
                                                    <ui:TextBox x:Name="TxtCommercialComments"/>
                                                </StackPanel>
                                            </Grid>
                                            <ui:Button Content="Save Commercial KPIs" Click="BtnSaveCommercial_Click" Appearance="Primary" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </ui:Card>
                                </ScrollViewer>
                            </TabItem>

                            <!-- COMPLIANCE KPI -->
                            <TabItem Header="Compliance">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ui:Card Padding="16" Margin="12">
                                        <StackPanel >
                                            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Program Compliance &amp; Certifications KPI" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Certifications Needed:"/>
                                                    <ComboBox x:Name="CboCertsNeeded" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Required Certifications (Count):"/>
                                                    <ui:TextBox x:Name="TxtRequiredCerts"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Certifications Covered (%):"/>
                                                    <ui:TextBox x:Name="TxtCertsCovered"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Certs Expiring &lt; 3 Months (Count):"/>
                                                    <ui:TextBox x:Name="TxtCertsExp3"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Certs Expiring &lt; 6 Months (Count):"/>
                                                    <ui:TextBox x:Name="TxtCertsExp6"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Certs Expiring &lt; 12 Months (Count):"/>
                                                    <ui:TextBox x:Name="TxtCertsExp12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Program Compliance Status:"/>
                                                    <ComboBox x:Name="CboComplianceStatus" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="OK"/>
                                                        <ComboBoxItem Content="Deviation"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Tier Risk:"/>
                                                    <ComboBox x:Name="CboTierRisk" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Comments:"/>
                                                    <ui:TextBox x:Name="TxtComplianceComments"/>
                                                </StackPanel>
                                            </Grid>
                                            <ui:Button Content="Save Compliance KPIs" Click="BtnSaveCompliance_Click" Appearance="Primary" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </ui:Card>
                                </ScrollViewer>
                            </TabItem>

                            <!-- PROGRAM CONTROL KPI -->
                            <TabItem Header="Program Control">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ui:Card Padding="16" Margin="12">
                                        <StackPanel >
                                            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Program Control KPI" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Reported Revenue (Onitio):"/>
                                                    <ui:TextBox x:Name="TxtProgOnitioRev"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Reported Revenue (OEM):"/>
                                                    <ui:TextBox x:Name="TxtProgOemRev"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Variance (%):"/>
                                                    <ui:TextBox x:Name="TxtProgVariance"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Rebate Eligibility:"/>
                                                    <ComboBox x:Name="CboProgRebate" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Tier Progress (%):"/>
                                                    <ui:TextBox x:Name="TxtProgTierProgress"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Risk of Downgrade:"/>
                                                    <ComboBox x:Name="CboProgRisk" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Comments:"/>
                                                    <ui:TextBox x:Name="TxtProgComments"/>
                                                </StackPanel>
                                            </Grid>
                                            <ui:Button Content="Save Program Control KPIs" Click="BtnSaveProgramControl_Click" Appearance="Primary" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </ui:Card>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ESG KPI -->
                            <TabItem Header="Sustainability ESG">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ui:Card Padding="16" Margin="12">
                                        <StackPanel >
                                            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Sustainability &amp; ESG KPI" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Take-back / Recycling Program:"/>
                                                    <ComboBox x:Name="CboEsgTakeBack" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Refurbished / Second Life Support:"/>
                                                    <ComboBox x:Name="CboEsgRefurb" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Environmental Data Available:"/>
                                                    <ComboBox x:Name="CboEsgEnvData" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="ESG Compliance Status:"/>
                                                    <ComboBox x:Name="CboEsgCompliance" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="OK"/>
                                                        <ComboBoxItem Content="Deviation"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Logistics Emission Reduction Initiatives:"/>
                                                    <ui:TextBox x:Name="TxtEsgLogistics"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Sustainability Qualification Met:"/>
                                                    <ComboBox x:Name="CboEsgQualMet" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Comments:"/>
                                                    <ui:TextBox x:Name="TxtEsgComments"/>
                                                </StackPanel>
                                            </Grid>
                                            <ui:Button Content="Save Sustainability ESG KPIs" Click="BtnSaveEsg_Click" Appearance="Primary" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </ui:Card>
                                </ScrollViewer>
                            </TabItem>

                            <!-- OPERATIONAL KPI (Partner-wide) -->
                            <TabItem Header="Operational">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ui:Card Padding="16" Margin="12">
                                        <StackPanel >
                                            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Operational KPI (Partner-wide)" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="DOA Rate (%):"/>
                                                    <ui:TextBox x:Name="TxtOpDoaRate"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Avg RMA Lead Time (Days):"/>
                                                    <ui:TextBox x:Name="TxtOpRmaTime"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Asset Data Quality (%):"/>
                                                    <ui:TextBox x:Name="TxtOpDataQuality"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Operational Issues Count:"/>
                                                    <ui:TextBox x:Name="TxtOpIssuesCount"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Target Met:"/>
                                                    <ComboBox x:Name="CboOpTargetMet" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="Yes"/>
                                                        <ComboBoxItem Content="No"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Comments:"/>
                                                    <ui:TextBox x:Name="TxtOpComments"/>
                                                </StackPanel>
                                            </Grid>
                                            <ui:Button Content="Save Operational KPIs" Click="BtnSaveOperational_Click" Appearance="Primary" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </ui:Card>
                                </ScrollViewer>
                            </TabItem>

                            <!-- STRATEGIC KPI (Partner-wide) -->
                            <TabItem Header="Strategic">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ui:Card Padding="16" Margin="12">
                                        <StackPanel >
                                            <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Strategic KPI (Partner-wide)" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Degree of Standardization:"/>
                                                    <ComboBox x:Name="CboStratStd" HorizontalAlignment="Stretch">
                                                        <ComboBoxItem Content="High"/>
                                                        <ComboBoxItem Content="Medium"/>
                                                        <ComboBoxItem Content="Low"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Avg Time-to-Deploy (Days):"/>
                                                    <ui:TextBox x:Name="TxtStratDeployTime"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Customer Impact Score (1-5):"/>
                                                    <ui:TextBox x:Name="TxtStratImpactScore"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Strategic Fit Assessment:"/>
                                                    <ui:TextBox x:Name="TxtStratFit"/>
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" >
                                                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Comments:"/>
                                                    <ui:TextBox x:Name="TxtStratComments"/>
                                                </StackPanel>
                                            </Grid>
                                            <ui:Button Content="Save Strategic KPIs" Click="BtnSaveStrategic_Click" Appearance="Primary" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </ui:Card>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </TabItem>

                    <!-- ACTIVITIES TAB -->
                    <TabItem Header="Activities">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Activity list -->
                            <ui:Card Grid.Row="0" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Activity Log &amp; Timeline" Margin="0,0,0,8"/>
                                    <ListView Grid.Row="1" x:Name="LstActivities" BorderThickness="0" Background="Transparent">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#FFE5E5E5" BorderThickness="0,0,0,1" Padding="8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <ui:SymbolIcon Symbol="CalendarAgenda24" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Style="{DynamicResource BodyTextBlockStyle}" FontWeight="SemiBold" Text="{Binding Title}"/>
                                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="{Binding Description}" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="{Binding Owner}" FontWeight="SemiBold" Foreground="{ui:ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                        </StackPanel>
                                                        
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="{Binding ActivityDate}" HorizontalAlignment="Right"/>
                                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="{Binding Status}" Foreground="Green" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </ui:Card>

                            <!-- Add Activity -->
                            <ui:Card Grid.Row="1" Padding="12">
                                <StackPanel >
                                    <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Log New Activity" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" >
                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Activity Title:"/>
                                            <ui:TextBox x:Name="TxtNewActTitle" PlaceholderText="e.g. Executive Alignment Meeting"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,8" >
                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Type:"/>
                                            <ui:TextBox x:Name="TxtNewActType" PlaceholderText="e.g. QBR, Email, Call"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,8" >
                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Owner:"/>
                                            <ui:TextBox x:Name="TxtNewActOwner" PlaceholderText="e.g. August Eriksen"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" >
                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Description:"/>
                                            <ui:TextBox x:Name="TxtNewActDesc" PlaceholderText="Details..."/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,8,0" >
                                            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Activity Date:"/>
                                            <ui:TextBox x:Name="TxtNewActDate" PlaceholderText="yyyy-MM-dd"/>
                                        </StackPanel>

                                        <ui:Button Grid.Row="1" Grid.Column="2" Content="Log Activity" Click="BtnAddActivity_Click" Appearance="Secondary" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </StackPanel>
                            </ui:Card>
                        </Grid>
                    </TabItem>

                    <!-- CAMPAIGNS & CASES TAB -->
                    <TabItem Header="Campaigns &amp; Cases">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Campaigns -->
                            <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Marketing Campaigns" Margin="0,0,0,8"/>
                                    <ListView Grid.Row="1" x:Name="LstCampaigns" Height="180">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="100"/>
                                                <GridViewColumn Header="Budget" DisplayMemberBinding="{Binding Budget, StringFormat={}{0:C}}" Width="80"/>
                                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <StackPanel Grid.Row="2" Margin="0,8,0,0" >
                                        <ui:TextBox x:Name="TxtNewCampName" PlaceholderText="Campaign Name"/>
                                        <ui:TextBox x:Name="TxtNewCampBudget" PlaceholderText="Budget (e.g. 5000)"/>
                                        <ui:TextBox x:Name="TxtNewCampStatus" PlaceholderText="Status (e.g. Planned, Active)"/>
                                        <ui:Button Content="Add Campaign" Click="BtnAddCampaign_Click" Appearance="Secondary" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>

                            <!-- Customer Cases -->
                            <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Customer Reference Cases" Margin="0,0,0,8"/>
                                    <ListView Grid.Row="1" x:Name="LstCases" Height="180">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Customer" DisplayMemberBinding="{Binding CustomerName}" Width="110"/>
                                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding ApprovalStatus}" Width="80"/>
                                                <GridViewColumn Header="Owner" DisplayMemberBinding="{Binding Owner}" Width="90"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <StackPanel Grid.Row="2" Margin="0,8,0,0" >
                                        <ui:TextBox x:Name="TxtNewCaseCust" PlaceholderText="Customer Name"/>
                                        <ui:TextBox x:Name="TxtNewCaseOwner" PlaceholderText="Case Owner"/>
                                        <ui:TextBox x:Name="TxtNewCaseStatus" PlaceholderText="Approval Status (e.g. Approved)"/>
                                        <ui:Button Content="Add Reference Case" Click="BtnAddCase_Click" Appearance="Secondary" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </Grid>
                    </TabItem>

                    <!-- DOCUMENTS TAB -->
                    <TabItem Header="Documents">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ui:Card Grid.Row="0" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Linked Partner Documents" Margin="0,0,0,8"/>
                                    
                                    <ListView Grid.Row="1" x:Name="LstDocuments" MouseDoubleClick="LstDocuments_MouseDoubleClick">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="File Name" DisplayMemberBinding="{Binding FileName}" Width="250"/>
                                                <GridViewColumn Header="Asset Type" DisplayMemberBinding="{Binding AssetType}" Width="100"/>
                                                <GridViewColumn Header="Upload Date" DisplayMemberBinding="{Binding UploadDate, StringFormat={}{0:yyyy-MM-dd}}" Width="120"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </ui:Card>

                            <ui:Card Grid.Row="1" Padding="12">
                                <StackPanel >
                                    <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Text="Upload / Link Document" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0" x:Name="TxtDocAssetType" PlaceholderText="Asset Type (e.g. Contract, Certificate, QBR Presentation)" Margin="0,0,8,0"/>
                                        <ui:Button Grid.Column="1" Content="Browse &amp; Upload Document" Icon="DocumentAdd24" Click="BtnUploadDoc_Click" Appearance="Secondary" Margin="0,0,8,0" HorizontalAlignment="Stretch"/>
                                        <ui:Button Grid.Column="2" Content="Open Selected" Icon="FolderOpen24" Click="BtnOpenDoc_Click" Appearance="Primary"/>
                                    </Grid>
                                </StackPanel>
                            </ui:Card>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
