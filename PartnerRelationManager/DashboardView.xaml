<UserControl x:Class="PartnerRelationManager.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Text="SRM Main Dashboard" />
            <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" 
                          Text="High-level overview of partner statuses, compliance risk alerts, and upcoming activities." />
        </StackPanel>

        <!-- Stat Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Partners -->
            <ui:Card x:Name="CardTotalPartners" Grid.Column="0" Margin="0,0,8,0" Padding="12">
                <StackPanel>
                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Total Partners" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalPartners" Style="{DynamicResource TitleTextBlockStyle}" Text="0" Margin="0,4,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </ui:Card>

            <!-- Active Countries -->
            <ui:Card x:Name="CardActiveCountries" Grid.Column="1" Margin="8,0,8,0" Padding="12">
                <StackPanel>
                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Active Countries" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalCountries" Style="{DynamicResource TitleTextBlockStyle}" Text="0" Margin="0,4,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </ui:Card>

            <!-- Warnings Card -->
            <ui:Card Grid.Column="2" Margin="8,0,8,0" Padding="12" Background="#FFFDF0F0">
                <StackPanel>
                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Compliance Alerts" Foreground="#FFC42B1C"/>
                    <TextBlock x:Name="TxtComplianceWarnings" Style="{DynamicResource TitleTextBlockStyle}" Text="0" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="#FFC42B1C"/>
                </StackPanel>
            </ui:Card>

            <!-- Total Activities -->
            <ui:Card Grid.Column="3" Margin="8,0,0,0" Padding="12">
                <StackPanel>
                    <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="Total Activities" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalActivities" Style="{DynamicResource TitleTextBlockStyle}" Text="0" Margin="0,4,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Status Matrix & Warnings / Risks list -->
            <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title Matrix -->
                        <RowDefinition Height="Auto"/> <!-- Matrix Grid -->
                        <RowDefinition Height="Auto"/> <!-- Warnings Title -->
                        <RowDefinition Height="*"/>    <!-- Warnings List -->
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Partner Status Matrix" Margin="0,0,0,8"/>
                    
                    <!-- Status Matrix Grid -->
                    <Grid Grid.Row="1" Margin="0,0,0,16" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Headers -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{DynamicResource BodyTextBlockStyle}" FontWeight="Bold" Text="OEM Partner"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{DynamicResource BodyTextBlockStyle}" FontWeight="Bold" Text="NO" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{DynamicResource BodyTextBlockStyle}" FontWeight="Bold" Text="SE" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Style="{DynamicResource BodyTextBlockStyle}" FontWeight="Bold" Text="DK" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Style="{DynamicResource BodyTextBlockStyle}" FontWeight="Bold" Text="FI" HorizontalAlignment="Center"/>
                        
                        <!-- Dell -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{DynamicResource BodyTextBlockStyle}" Text="Dell" VerticalAlignment="Center" Margin="0,4"/>
                        <Ellipse x:Name="Dot_Dell_NO" Grid.Row="1" Grid.Column="1" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_Dell_SE" Grid.Row="1" Grid.Column="2" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_Dell_DK" Grid.Row="1" Grid.Column="3" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_Dell_FI" Grid.Row="1" Grid.Column="4" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        
                        <!-- HP -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{DynamicResource BodyTextBlockStyle}" Text="HP" VerticalAlignment="Center" Margin="0,4"/>
                        <Ellipse x:Name="Dot_HP_NO" Grid.Row="2" Grid.Column="1" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_HP_SE" Grid.Row="2" Grid.Column="2" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_HP_DK" Grid.Row="2" Grid.Column="3" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_HP_FI" Grid.Row="2" Grid.Column="4" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        
                        <!-- Lenovo -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{DynamicResource BodyTextBlockStyle}" Text="Lenovo" VerticalAlignment="Center" Margin="0,4"/>
                        <Ellipse x:Name="Dot_Lenovo_NO" Grid.Row="3" Grid.Column="1" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_Lenovo_SE" Grid.Row="3" Grid.Column="2" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_Lenovo_DK" Grid.Row="3" Grid.Column="3" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Ellipse x:Name="Dot_Lenovo_FI" Grid.Row="3" Grid.Column="4" Width="14" Height="14" Fill="#FF888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>
                    
                    <TextBlock Grid.Row="2" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Compliance Warnings &amp; Risks" Margin="0,0,0,12"/>
                    
                    <ListView x:Name="LstWarnings" Grid.Row="3" BorderThickness="0" Background="Transparent" 
                               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFE5E5E5" BorderThickness="0,0,0,1" Padding="8,10,8,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Alert Icon/Visual -->
                                        <Border Background="#FFFDF0F0" CornerRadius="4" Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <ui:SymbolIcon Symbol="Warning12" Foreground="#FFC42B1C" Filled="True"/>
                                        </Border>
                                        
                                        <!-- Text -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <!-- Colored accent block -->
                                                <Border Background="{Binding SeverityColor}" Width="4" Height="14" CornerRadius="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Style="{DynamicResource BodyTextBlockStyle}" FontWeight="SemiBold" Text="{Binding DisplayTitle}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Style="{DynamicResource CaptionTextBlockStyle}" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Text="{Binding DisplayDetails}" TextWrapping="Wrap" Margin="10,2,0,0"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </ui:Card>

            <!-- Upcoming Activities -->
            <ui:Card Grid.Column="1" Margin="8,0,0,0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Style="{DynamicResource SubtitleTextBlockStyle}" Text="Upcoming / Recent Activities" Margin="0,0,0,12"/>
                    
                    <ListView x:Name="LstActivities" Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FFE5E5E5" BorderThickness="0,0,0,1" Padding="4,8,4,8">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{DynamicResource BodyTextBlockStyle}" FontWeight="SemiBold" Text="{Binding Title}"/>
                                            <TextBlock Grid.Column="1" Style="{DynamicResource CaptionTextBlockStyle}" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Text="{Binding DisplayDate}"/>
                                        </Grid>
                                        <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Text="{Binding PartnerName}" FontWeight="SemiBold" Foreground="{ui:ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                        <TextBlock Style="{DynamicResource CaptionTextBlockStyle}" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Status}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
